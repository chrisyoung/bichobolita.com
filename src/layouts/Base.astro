---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Bicho Bolita', description = 'A work of art for the playa.' } = Astro.props;
const url = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Bicho Bolita" />
    <meta property="og:image" content="https://bichobolita.com/images/bicho-bolita.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://bichobolita.com/images/bicho-bolita.jpg" />
    <style>
      :root {
        --color-bg: #0a0a0a;
        --color-text: #e8e4df;
        --color-muted: #9a938b;
        --color-accent: #c9a96e;
        --color-rule: #2a2520;
        --max-width: 42rem;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 18px;
      }

      body {
        font-family: Georgia, 'Times New Roman', serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        padding: 3rem 1.5rem;
      }

      nav {
        max-width: var(--max-width);
        margin: 0 auto 2rem;
        display: flex;
        gap: 1.5rem;
      }

      nav a {
        color: var(--color-muted);
        text-decoration: none;
        font-size: 0.9rem;
        letter-spacing: 0.03em;
      }

      nav a:hover {
        color: var(--color-accent);
      }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Creative Framework</a>
      <a href="/seeds">Seeds</a>
      <a href="/experimentation">Experimentation</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
